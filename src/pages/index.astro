---
// AVFX Festival 2026 - Sito completo
// Ricostruito da Kit 🏗️ — WebDev Agent
---
<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AVFX Festival 2026 — Festival degli Effetti Visivi e dell'Animazione CGI</title>
  <meta name="description" content="AVFX Festival 2026 — Festival degli Effetti Visivi e dell'Animazione CGI. 18 Aprile 2026, Nuovo Cinema Aquila, Roma. Ingresso gratuito." />
  <meta name="theme-color" content="#0a0a1a" />
  <!-- Open Graph -->
  <meta property="og:title" content="AVFX Festival 2026" />
  <meta property="og:description" content="18 Aprile 2026 · Roma · VFX · Virtual Production · Animation · AI" />
  <meta property="og:type" content="website" />
  <!-- Google Fonts: Inter -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&display=swap" rel="stylesheet" />

  <style>
    /* ============================================
       RESET & BASE
    ============================================ */
    *, *::before, *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --bg-dark: #0a0a1a;
      --bg-section: #0f0f2a;
      --bg-light: #ffffff;
      --accent-purple: #6B21A8;
      --accent-purple-light: #7C3AED;
      --accent-magenta: #D946EF;
      --accent-cyan: #06B6D4;
      --text-white: #ffffff;
      --text-light: #e2e8f0;
      --text-gray: #94a3b8;
      --text-dark: #1a1a2e;
      --badge-red: #EF4444;
      --badge-green: #10B981;
      --badge-purple: #7C3AED;
      --badge-cyan: #06B6D4;
      --radius-card: 14px;
      --font: 'Inter', system-ui, -apple-system, sans-serif;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: var(--font);
      background: var(--bg-dark);
      color: var(--text-white);
      line-height: 1.6;
      overflow-x: hidden;
    }

    img { display: block; max-width: 100%; }
    a { text-decoration: none; color: inherit; }
    button { font-family: var(--font); cursor: pointer; }

    /* ============================================
       SCROLL ANIMATION — FADE IN
    ============================================ */
    .fade-in {
      opacity: 0;
      transform: translateY(30px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
    .fade-in.visible {
      opacity: 1;
      transform: translateY(0);
    }
    .fade-in-delay-1 { transition-delay: 0.1s; }
    .fade-in-delay-2 { transition-delay: 0.2s; }
    .fade-in-delay-3 { transition-delay: 0.3s; }

    /* ============================================
       NAVIGATION
    ============================================ */
    .nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      background: rgba(10, 10, 26, 0.92);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(107, 33, 168, 0.3);
      padding: 0 1.5rem;
    }

    .nav-inner {
      max-width: 1200px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 64px;
    }

    .nav-logo {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-weight: 900;
      font-size: 1.3rem;
      letter-spacing: 1px;
      text-transform: uppercase;
    }

    .nav-logo-badge {
      background: linear-gradient(135deg, var(--accent-purple), var(--accent-magenta));
      color: white;
      padding: 0.25rem 0.6rem;
      border-radius: 6px;
      font-size: 1rem;
      font-weight: 900;
      letter-spacing: 2px;
    }

    .nav-logo-text {
      color: var(--text-white);
      font-size: 0.85rem;
      font-weight: 600;
      letter-spacing: 1px;
      opacity: 0.7;
      display: none;
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 2rem;
      list-style: none;
    }

    .nav-links a {
      font-size: 0.85rem;
      font-weight: 600;
      letter-spacing: 0.5px;
      text-transform: uppercase;
      color: var(--text-light);
      opacity: 0.8;
      transition: opacity 0.2s, color 0.2s;
    }

    .nav-links a:hover {
      opacity: 1;
      color: var(--accent-magenta);
    }

    .nav-cta {
      background: linear-gradient(135deg, var(--accent-purple), var(--accent-magenta));
      color: white !important;
      opacity: 1 !important;
      padding: 0.5rem 1.2rem;
      border-radius: 50px;
      font-weight: 700 !important;
      transition: transform 0.2s, box-shadow 0.2s !important;
    }

    .nav-cta:hover {
      transform: scale(1.05);
      box-shadow: 0 0 20px rgba(217, 70, 239, 0.5);
    }

    /* Mobile nav */
    .nav-hamburger {
      display: none;
      flex-direction: column;
      gap: 5px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 4px;
    }

    .nav-hamburger span {
      display: block;
      width: 24px;
      height: 2px;
      background: white;
      border-radius: 2px;
      transition: transform 0.3s;
    }

    /* ============================================
       HERO
    ============================================ */
    .hero {
      position: relative;
      min-height: 100vh;
      display: flex;
      align-items: center;
      overflow: hidden;
      padding: 100px 1.5rem 60px;
      background: var(--bg-dark);
    }

    /* Gradient background nebula effect */
    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 80% 60% at 20% 50%, rgba(107, 33, 168, 0.45) 0%, transparent 60%),
        radial-gradient(ellipse 60% 50% at 80% 30%, rgba(217, 70, 239, 0.25) 0%, transparent 55%),
        radial-gradient(ellipse 50% 40% at 60% 80%, rgba(6, 182, 212, 0.15) 0%, transparent 50%),
        radial-gradient(ellipse 40% 30% at 90% 70%, rgba(107, 33, 168, 0.3) 0%, transparent 50%);
      z-index: 0;
    }

    /* Light streaks */
    .hero::after {
      content: '';
      position: absolute;
      inset: 0;
      background:
        linear-gradient(105deg, transparent 20%, rgba(217, 70, 239, 0.07) 30%, transparent 40%),
        linear-gradient(108deg, transparent 35%, rgba(107, 33, 168, 0.1) 45%, transparent 55%),
        linear-gradient(102deg, transparent 50%, rgba(6, 182, 212, 0.06) 60%, transparent 70%),
        linear-gradient(112deg, transparent 10%, rgba(217, 70, 239, 0.05) 25%, transparent 35%);
      z-index: 0;
    }

    /* Grid overlay for tech feel */
    .hero-grid-overlay {
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(107, 33, 168, 0.08) 1px, transparent 1px),
        linear-gradient(90deg, rgba(107, 33, 168, 0.08) 1px, transparent 1px);
      background-size: 60px 60px;
      z-index: 0;
      mask-image: radial-gradient(ellipse 70% 70% at 50% 50%, black 20%, transparent 80%);
    }

    .hero-inner {
      position: relative;
      z-index: 1;
      max-width: 1200px;
      margin: 0 auto;
      width: 100%;
      display: grid;
      grid-template-columns: 1fr;
      gap: 3rem;
      align-items: center;
    }

    .hero-content {
      text-align: center;
    }

    .hero-event-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: rgba(107, 33, 168, 0.3);
      border: 1px solid rgba(217, 70, 239, 0.4);
      padding: 0.4rem 1rem;
      border-radius: 50px;
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: var(--accent-magenta);
      margin-bottom: 1.5rem;
    }

    .hero-event-badge .dot {
      width: 7px;
      height: 7px;
      background: var(--accent-magenta);
      border-radius: 50%;
      animation: pulse 2s infinite;
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.5; transform: scale(1.4); }
    }

    .hero-title {
      font-size: clamp(3rem, 10vw, 7rem);
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 2px;
      line-height: 0.95;
      margin-bottom: 1rem;
      background: linear-gradient(135deg, #ffffff 0%, #e2d9f3 40%, var(--accent-magenta) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .hero-subtitle {
      font-size: clamp(0.75rem, 2vw, 1rem);
      font-weight: 700;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--accent-cyan);
      margin-bottom: 1.2rem;
      opacity: 0.9;
    }

    .hero-tagline {
      font-size: clamp(1rem, 2.5vw, 1.3rem);
      font-weight: 400;
      color: var(--text-light);
      margin-bottom: 0.6rem;
      font-style: italic;
      opacity: 0.85;
    }

    .hero-desc {
      font-size: 0.95rem;
      color: var(--text-gray);
      margin-bottom: 2.5rem;
    }

    .hero-meta {
      display: flex;
      align-items: center;
      justify-content: center;
      flex-wrap: wrap;
      gap: 1.5rem;
      margin-bottom: 2.5rem;
    }

    .hero-meta-item {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.9rem;
      color: var(--text-light);
    }

    .hero-meta-item svg {
      opacity: 0.7;
    }

    .hero-actions {
      display: flex;
      align-items: center;
      justify-content: center;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: linear-gradient(135deg, var(--accent-purple), var(--accent-magenta));
      color: white;
      padding: 0.9rem 2.2rem;
      border-radius: 50px;
      font-weight: 700;
      font-size: 1rem;
      border: none;
      transition: transform 0.2s, box-shadow 0.2s;
      letter-spacing: 0.5px;
    }

    .btn-primary:hover {
      transform: scale(1.05) translateY(-2px);
      box-shadow: 0 8px 30px rgba(217, 70, 239, 0.5);
    }

    .btn-outline {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: transparent;
      color: white;
      padding: 0.9rem 2.2rem;
      border-radius: 50px;
      font-weight: 600;
      font-size: 1rem;
      border: 2px solid rgba(255, 255, 255, 0.4);
      transition: border-color 0.2s, background 0.2s;
    }

    .btn-outline:hover {
      border-color: white;
      background: rgba(255, 255, 255, 0.08);
    }

    /* Floating orbs decoration */
    .hero-orb {
      position: absolute;
      border-radius: 50%;
      filter: blur(80px);
      pointer-events: none;
    }

    .hero-orb-1 {
      width: 400px;
      height: 400px;
      background: rgba(107, 33, 168, 0.25);
      top: -10%;
      right: -5%;
    }

    .hero-orb-2 {
      width: 300px;
      height: 300px;
      background: rgba(217, 70, 239, 0.2);
      bottom: 10%;
      left: -5%;
    }

    .hero-orb-3 {
      width: 200px;
      height: 200px;
      background: rgba(6, 182, 212, 0.15);
      top: 40%;
      right: 20%;
    }

    /* ============================================
       SECTION SHARED STYLES
    ============================================ */
    .section-label {
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 3px;
      text-transform: uppercase;
      margin-bottom: 0.75rem;
    }

    .section-title {
      font-size: clamp(2rem, 5vw, 3.5rem);
      font-weight: 900;
      text-transform: uppercase;
      line-height: 1.05;
      margin-bottom: 1rem;
    }

    .section-subtitle {
      font-size: 1.1rem;
      opacity: 0.7;
      max-width: 500px;
    }

    /* ============================================
       ABOUT — 3 COLONNE
    ============================================ */
    .about {
      background: #ffffff;
      color: var(--text-dark);
      padding: 80px 1.5rem;
    }

    .about-inner {
      max-width: 1200px;
      margin: 0 auto;
    }

    .about-header {
      text-align: center;
      margin-bottom: 3.5rem;
    }

    .about-header .section-label {
      color: var(--accent-purple);
    }

    .about-header .section-title {
      color: var(--text-dark);
    }

    .about-header .section-subtitle {
      color: #555;
      margin: 0 auto;
    }

    .about-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .about-card {
      background: #f8f6ff;
      border-radius: var(--radius-card);
      padding: 2.5rem 2rem;
      border: 1px solid rgba(107, 33, 168, 0.1);
      transition: transform 0.3s, box-shadow 0.3s;
    }

    .about-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 40px rgba(107, 33, 168, 0.15);
    }

    .about-card-icon {
      width: 52px;
      height: 52px;
      background: linear-gradient(135deg, var(--accent-purple), var(--accent-magenta));
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1.2rem;
    }

    .about-card-icon svg {
      width: 26px;
      height: 26px;
      color: white;
    }

    .about-card h3 {
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--text-dark);
      margin-bottom: 0.75rem;
    }

    .about-card p {
      font-size: 0.95rem;
      color: #555;
      line-height: 1.7;
    }

    /* ============================================
       FEATURED SPEAKERS
    ============================================ */
    .speakers {
      background: var(--bg-dark);
      padding: 80px 1.5rem;
      position: relative;
      overflow: hidden;
    }

    .speakers::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 60% 40% at 0% 50%, rgba(107, 33, 168, 0.2) 0%, transparent 60%),
        radial-gradient(ellipse 40% 30% at 100% 50%, rgba(217, 70, 239, 0.15) 0%, transparent 60%);
      pointer-events: none;
    }

    .speakers-inner {
      position: relative;
      z-index: 1;
      max-width: 1200px;
      margin: 0 auto;
    }

    .speakers-header {
      text-align: center;
      margin-bottom: 3.5rem;
    }

    .speakers-header .section-label {
      color: var(--accent-magenta);
    }

    .speakers-header .section-title {
      color: var(--text-white);
    }

    .speakers-header .section-subtitle {
      color: var(--text-gray);
      margin: 0 auto;
    }

    .speakers-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 1.25rem;
    }

    /* Speaker card */
    .speaker-card {
      background: linear-gradient(145deg, #12122a, #1a1040);
      border-radius: var(--radius-card);
      overflow: hidden;
      border: 1px solid rgba(107, 33, 168, 0.3);
      transition: transform 0.3s, box-shadow 0.3s, border-color 0.3s;
      position: relative;
    }

    .speaker-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 16px 50px rgba(107, 33, 168, 0.4);
      border-color: rgba(217, 70, 239, 0.5);
    }

    /* Card glow on hover */
    .speaker-card::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(217, 70, 239, 0.05), transparent 50%);
      opacity: 0;
      transition: opacity 0.3s;
      pointer-events: none;
    }

    .speaker-card:hover::before {
      opacity: 1;
    }

    .speaker-photo-wrap {
      position: relative;
      aspect-ratio: 1;
      overflow: hidden;
    }

    .speaker-photo {
      width: 100%;
      height: 100%;
      object-fit: cover;
      border-radius: 12px 12px 0 0;
    }
    .speaker-photo-placeholder {
      width: 100%;
      height: 100%;
      background: linear-gradient(135deg, #1e1040 0%, #2d1b69 50%, #1e1040 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 3rem;
      font-weight: 900;
      color: rgba(255, 255, 255, 0.2);
      letter-spacing: -2px;
    }

    .speaker-photo-placeholder .initials {
      background: linear-gradient(135deg, rgba(217, 70, 239, 0.5), rgba(107, 33, 168, 0.5));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      font-size: 2.5rem;
    }

    .speaker-location-badge {
      position: absolute;
      bottom: 10px;
      right: 10px;
      padding: 0.25rem 0.65rem;
      border-radius: 20px;
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.5px;
      text-transform: uppercase;
      color: white;
      z-index: 2;
    }

    .badge-red    { background: var(--badge-red); }
    .badge-green  { background: var(--badge-green); }
    .badge-purple { background: var(--badge-purple); }
    .badge-cyan   { background: var(--badge-cyan); }

    .speaker-info {
      padding: 1rem;
    }

    .speaker-name {
      font-size: 0.95rem;
      font-weight: 700;
      color: var(--text-white);
      margin-bottom: 0.25rem;
      line-height: 1.2;
    }

    .speaker-role {
      font-size: 0.75rem;
      color: var(--accent-magenta);
      font-weight: 600;
      margin-bottom: 0.2rem;
      line-height: 1.3;
    }

    .speaker-company {
      font-size: 0.72rem;
      color: var(--text-gray);
      line-height: 1.3;
    }

    .speaker-credits {
      display: flex;
      flex-wrap: wrap;
      gap: 0.3rem;
      margin-top: 0.6rem;
    }

    .speaker-credit-tag {
      background: rgba(107, 33, 168, 0.25);
      border: 1px solid rgba(107, 33, 168, 0.4);
      padding: 0.15rem 0.5rem;
      border-radius: 4px;
      font-size: 0.62rem;
      color: var(--text-light);
      font-weight: 600;
    }

    .speaker-award {
      background: rgba(245, 158, 11, 0.2);
      border: 1px solid rgba(245, 158, 11, 0.4);
      color: #fbbf24;
      padding: 0.15rem 0.5rem;
      border-radius: 4px;
      font-size: 0.62rem;
      font-weight: 700;
    }

    .speaker-event-tag {
      display: block;
      margin-top: 0.75rem;
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.5px;
      text-transform: uppercase;
      color: var(--text-gray);
      opacity: 0.7;
    }

    /* ============================================
       NEWSLETTER
    ============================================ */
    .newsletter {
      background: var(--bg-light);
      padding: 80px 1.5rem;
    }

    .newsletter-inner {
      max-width: 600px;
      margin: 0 auto;
      text-align: center;
    }

    .newsletter .section-label {
      color: var(--accent-purple);
    }

    .newsletter h2 {
      font-size: clamp(2rem, 5vw, 3rem);
      font-weight: 900;
      color: var(--text-dark);
      text-transform: uppercase;
      margin-bottom: 0.75rem;
    }

    .newsletter p {
      color: #555;
      margin-bottom: 2rem;
      font-size: 1rem;
    }

    .newsletter-form {
      display: flex;
      gap: 0.75rem;
      max-width: 480px;
      margin: 0 auto;
      flex-direction: column;
    }

    .newsletter-form input {
      flex: 1;
      padding: 0.9rem 1.3rem;
      border: 2px solid rgba(107, 33, 168, 0.25);
      border-radius: 50px;
      font-size: 0.95rem;
      font-family: var(--font);
      background: #f8f6ff;
      color: var(--text-dark);
      outline: none;
      transition: border-color 0.2s;
    }

    .newsletter-form input:focus {
      border-color: var(--accent-purple);
    }

    .newsletter-form input::placeholder {
      color: #aaa;
    }

    .newsletter-form button {
      background: linear-gradient(135deg, var(--accent-purple), var(--accent-magenta));
      color: white;
      padding: 0.9rem 2rem;
      border-radius: 50px;
      font-size: 1rem;
      font-weight: 700;
      border: none;
      transition: transform 0.2s, box-shadow 0.2s;
      white-space: nowrap;
    }

    .newsletter-form button:hover {
      transform: scale(1.04);
      box-shadow: 0 6px 24px rgba(217, 70, 239, 0.45);
    }

    .newsletter-note {
      margin-top: 1rem;
      font-size: 0.8rem;
      color: #999;
    }

    /* ============================================
       FOOTER
    ============================================ */
    .footer {
      background: #0a0a14;
      color: var(--text-white);
      padding: 60px 1.5rem 30px;
      border-top: 1px solid rgba(107, 33, 168, 0.25);
    }

    .footer-inner {
      max-width: 1200px;
      margin: 0 auto;
    }

    .footer-top {
      display: grid;
      grid-template-columns: 1fr;
      gap: 2.5rem;
      margin-bottom: 3rem;
    }

    .footer-logo {
      font-size: 1.8rem;
      font-weight: 900;
      letter-spacing: 2px;
      text-transform: uppercase;
      background: linear-gradient(135deg, white, var(--accent-magenta));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 0.75rem;
    }

    .footer-tagline {
      font-size: 0.85rem;
      color: var(--text-gray);
      margin-bottom: 1.2rem;
      line-height: 1.6;
      max-width: 300px;
    }

    .footer-social {
      display: flex;
      gap: 0.75rem;
    }

    .footer-social a {
      width: 40px;
      height: 40px;
      background: rgba(107, 33, 168, 0.2);
      border: 1px solid rgba(107, 33, 168, 0.4);
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background 0.2s, border-color 0.2s, transform 0.2s;
    }

    .footer-social a:hover {
